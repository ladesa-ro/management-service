    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.1.6",
    "compression": "^1.8.1",
    "fs-jetpack": "^5.1.0",
    "graphql": "^16.13.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "lodash": "^4.18.1",
    "lru-cache": "^11.3.2",
    "nestjs-paginate": "^12.9.0",
    "openid-client": "^6.8.2",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "pg": "^8.20.0",
    "rascal": "^21.0.1",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "ts-mixer": "^6.0.4",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bun": "^1.3.11",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/json-schema": "^7.0.15",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/passport-http-bearer": "^1.0.42",
    "@types/rascal": "^10.2.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "nx": "22.6.4",
    "quicktype": "^23.2.6",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "dev": "nx run @ladesa-ro/management-service:dev",
    "typecheck": "nx run @ladesa-ro/management-service:typecheck",
    "debug": "nx run @ladesa-ro/management-service:debug",
    "start": "nx run @ladesa-ro/management-service:start",
    "test": "nx run @ladesa-ro/management-service:test",
    "test:cov": "commands/test-cov",
    "test:debug": "commands/test-debug",
    "test:e2e": "commands/test-e2e",
    "test:watch": "commands/test-watch",
    "typeorm": "commands/typeorm",
    "typeorm:create": "commands/typeorm-create",
    "typeorm:entity": "commands/typeorm-entity",
    "typeorm:generate": "commands/typeorm-generate",
    "migration:revert": "commands/migration-revert",
    "migration:run": "commands/migration-run",
    "db:drop": "commands/db-drop",
    "db:reset": "commands/db-reset",
    "code:check": "commands/code-check",
    "code:check:format": "commands/code-check-format",
    "code:check:lint": "commands/code-check-lint",
    "code:fix": "commands/code-fix",
    "code:fix:format": "commands/code-fix-format",
    "code:fix:lint": "commands/code-fix-lint",
    "modulecheck": "nx run @ladesa-ro/management-service:modulecheck",
    "check": "nx run @ladesa-ro/management-service:check"
  },
  "nx": {
    "targets": {
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/dev",
          "cwd": "{projectRoot}"
        }
      },
      "start": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/start",
          "cwd": "{projectRoot}"
        }
      },
      "debug": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/debug",
          "cwd": "{projectRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/test",
          "cwd": "{projectRoot}"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/typecheck",
          "cwd": "{projectRoot}"
        }
      },
      "codegen:timetable-generator:fresh": {
        "executor": "nx:run-commands",
        "cache": true,
        "inputs": [
          "{projectRoot}/infrastructure.timetable-generator/messages/commands/generate"
        ],
        "outputs": [
          "{projectRoot}/infrastructure.timetable-generator/messages/schemas.ts"
        ],
        "options": {
          "command": "bash commands/generate",
          "cwd": "{projectRoot}/infrastructure.timetable-generator/messages"
        }
      },
      "modulecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/modulecheck",
          "cwd": "{projectRoot}"
        }
      },
      "check": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bash commands/check",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
